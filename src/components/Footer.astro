---
import { localizeUrl, type Locale, type RouteKey } from '~/i18n/ui';
import { useTranslations } from '~/i18n/t';
import { site } from '~/data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const siteLinks: { key: RouteKey; label: string }[] = [
  { key: 'house', label: t('nav.house') },
  { key: 'pool', label: t('nav.pool') },
  { key: 'rates', label: t('nav.rates') },
  { key: 'discover', label: t('nav.discover') },
  { key: 'reviews', label: t('nav.reviews') },
  { key: 'contact', label: t('nav.contact') },
];
---

<footer class="bg-footer text-footer-text">
  <div class="mx-auto max-w-[1440px] px-5 pt-14 pb-8 md:px-14">
    <div class="border-cream/20 grid gap-10 border-b pb-9 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <p class="font-display text-footer-title text-xl font-semibold">
          La petite maison sous les pins
        </p>
        <address class="mt-4 text-sm leading-[1.9] not-italic">
          {site.address.street}<br />
          {site.address.postalCode}
          {site.address.city} ({site.address.district})<br />
          <a href={`tel:${site.phoneFixed}`} class="text-footer-text no-underline hover:underline"
            >{t('common.phoneFixed')}</a
          >
          ·
          <a href={`tel:${site.phoneMobile}`} class="text-footer-text no-underline hover:underline"
            >{t('common.phoneMobile')}</a
          ><br />
          <a
            href={localizeUrl(locale, 'contact')}
            class="text-footer-text hover:text-footer-title underline">{t('footer.contactForm')}</a
          >
        </address>
      </div>

      <nav aria-label={t('footer.siteMap')}>
        <p class="text-footer-label mb-4 text-[13px] font-semibold tracking-[0.12em] uppercase">
          {t('footer.siteMap')}
        </p>
        <ul class="space-y-1.5 text-sm">
          {
            siteLinks.map((l) => (
              <li>
                <a
                  href={localizeUrl(locale, l.key)}
                  class="text-footer-text hover:text-footer-title no-underline hover:underline"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class="text-footer-label mb-4 text-[13px] font-semibold tracking-[0.12em] uppercase">
          {t('footer.infoLabel')}
        </p>
        <p class="text-sm leading-[1.9]">
          {t('footer.familyPool')}<br />
          <span class="text-[#e8b4a0]">{t('footer.noParties')}</span>
        </p>
        <nav aria-label="Légal" class="mt-4 flex flex-col gap-1.5 text-sm">
          <a
            href={localizeUrl(locale, 'legal')}
            class="text-footer-text no-underline hover:underline">{t('footer.legal')}</a
          >
          <a
            href={localizeUrl(locale, 'privacy')}
            class="text-footer-text no-underline hover:underline">{t('footer.privacy')}</a
          >
          <a
            href={localizeUrl(locale, 'terms')}
            class="text-footer-text no-underline hover:underline">{t('footer.terms')}</a
          >
        </nav>
      </div>
    </div>

    <p class="text-footer-label pt-6 text-[13px]">
      © 2026 {site.name} · {site.address.district}, {site.address.city} · SIRET {site.siret}
    </p>
  </div>
</footer>
