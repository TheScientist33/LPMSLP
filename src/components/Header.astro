---
import { localizeUrl, type Locale, type RouteKey } from '~/i18n/ui';
import { useTranslations } from '~/i18n/t';
import { site } from '~/data/site';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const navItems: { key: RouteKey; label: string }[] = [
  { key: 'home', label: t('nav.home') },
  { key: 'house', label: t('nav.house') },
  { key: 'pool', label: t('nav.pool') },
  { key: 'rates', label: t('nav.rates') },
  { key: 'discover', label: t('nav.discover') },
  { key: 'reviews', label: t('nav.reviews') },
  { key: 'contact', label: t('nav.contact') },
];

const current = Astro.url.pathname.replace(/\/$/, '');
const isActive = (key: RouteKey) => current === localizeUrl(locale, key).replace(/\/$/, '');
---

<header class="sticky top-0 z-40 border-b border-beige bg-cream/95 backdrop-blur">
  <div class="mx-auto flex max-w-[1440px] items-center justify-between gap-4 px-5 py-4 md:px-14 md:py-[22px]">
    <a
      href={localizeUrl(locale, 'home')}
      class="font-display text-base font-semibold leading-tight text-ink no-underline md:text-[22px]"
    >
      La petite maison sous les <span class="text-pine">pins</span>
    </a>

    <nav aria-label={t('nav.menu')} class="hidden items-center gap-[26px] xl:flex">
      {
        navItems.map((item) => (
          <a
            href={localizeUrl(locale, item.key)}
            aria-current={isActive(item.key) ? 'page' : undefined}
            class:list={[
              'text-[15px] font-medium no-underline transition-colors',
              isActive(item.key) ? 'font-semibold text-pine' : 'text-ink hover:text-marine',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-[18px] xl:flex">
      <LanguageSwitcher locale={locale} />
      <a
        href={localizeUrl(locale, 'rates')}
        class="inline-flex items-center rounded-[5px] bg-pine px-[18px] py-2.5 text-sm font-medium text-cream no-underline transition-colors hover:bg-pine/90"
      >
        {t('common.availability')}
      </a>
    </div>

    <!-- Mobile -->
    <div class="flex items-center gap-3 xl:hidden">
      <a
        href={`tel:${site.phoneMobile}`}
        aria-label={t('nav.call')}
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border-[1.5px] border-pine text-pine"
      >
        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M3.5 3h3l1.2 3.2-1.6 1.1a10 10 0 004.6 4.6l1.1-1.6L16 14.5v3a1.5 1.5 0 01-1.6 1.5A13.5 13.5 0 012 4.6 1.5 1.5 0 013.5 3z" />
        </svg>
      </a>
      <button
        type="button"
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded-lg text-ink"
      >
        <span class="sr-only">{t('nav.menu')}</span>
        <span aria-hidden="true" class="block h-0.5 w-[22px] bg-ink"></span>
        <span aria-hidden="true" class="block h-0.5 w-[22px] bg-ink"></span>
        <span aria-hidden="true" class="block h-0.5 w-[22px] bg-ink"></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" hidden class="border-t border-beige xl:hidden">
    <nav aria-label={t('nav.menu')} class="mx-auto flex max-w-[1440px] flex-col px-5 py-2">
      {
        navItems.map((item) => (
          <a
            href={localizeUrl(locale, item.key)}
            aria-current={isActive(item.key) ? 'page' : undefined}
            class:list={[
              'border-b border-beige/60 py-3 no-underline last:border-0',
              isActive(item.key) ? 'font-semibold text-pine' : 'text-ink',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <div class="flex items-center justify-between py-3">
        <LanguageSwitcher locale={locale} />
        <a
          href={localizeUrl(locale, 'rates')}
          class="inline-flex items-center rounded-[5px] bg-pine px-4 py-2 text-sm font-medium text-cream no-underline"
        >
          {t('common.availability')}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
</script>
