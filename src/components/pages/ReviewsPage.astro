---
import { useTranslations } from '~/i18n/t';
import type { Locale } from '~/i18n/ui';
import Section from '~/components/Section.astro';
import ReviewsGoogle from '~/components/ReviewsGoogle.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Section>
  <h1 class="text-3xl md:text-4xl">{t('reviews.title')}</h1>
  <p class="mt-4 max-w-3xl text-muted">{t('reviews.intro')}</p>
  <div class="mt-10">
    <ReviewsGoogle locale={locale} />
  </div>
</Section>
