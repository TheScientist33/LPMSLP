---
import { useTranslations } from '~/i18n/t';
import { localizeUrl, type Locale } from '~/i18n/ui';
import Section from '~/components/Section.astro';
import Button from '~/components/Button.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const highlights = t<{ title: string; text: string }[]>('home.highlights');
---

<!-- Hero -->
<section class="bg-sand/50">
  <div class="mx-auto max-w-6xl px-4 py-20 md:px-6 md:py-28">
    <p class="text-sm uppercase tracking-widest text-sage">{t('home.heroKicker')}</p>
    <h1 class="mt-4 max-w-3xl text-4xl md:text-5xl">{t('home.heroTitle')}</h1>
    <p class="mt-6 max-w-2xl text-lg text-muted">{t('home.heroSubtitle')}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href={localizeUrl(locale, 'rates')}>{t('common.bookNow')}</Button>
      <Button href={localizeUrl(locale, 'house')} variant="outline">{t('common.discoverHouse')}</Button>
    </div>
  </div>
</section>

<!-- Points forts -->
<Section>
  <h2 class="text-2xl md:text-3xl">{t('home.highlightsTitle')}</h2>
  <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      highlights.map((h) => (
        <li class="fade-up rounded border border-beige bg-white/50 p-6 shadow-sm">
          <h3 class="text-lg">{h.title}</h3>
          <p class="mt-2 text-sm text-muted">{h.text}</p>
        </li>
      ))
    }
  </ul>
</Section>

<!-- Deux façons de séjourner -->
<Section tone="beige">
  <h2 class="text-2xl md:text-3xl">{t('home.waysTitle')}</h2>
  <div class="mt-8 grid gap-6 md:grid-cols-2">
    <div class="fade-up rounded border border-beige bg-cream p-8">
      <h3 class="text-xl">{t('home.weekTitle')}</h3>
      <p class="mt-3 text-muted">{t('home.weekText')}</p>
      <p class="mt-6">
        <a href={localizeUrl(locale, 'rates')} class="text-marine hover:underline"
          >{t('common.seeRates')} →</a
        >
      </p>
    </div>
    <div class="fade-up rounded border border-beige bg-cream p-8">
      <h3 class="text-xl">{t('home.monthTitle')}</h3>
      <p class="mt-3 text-muted">{t('home.monthText')}</p>
      <p class="mt-6">
        <a href={localizeUrl(locale, 'rates')} class="text-marine hover:underline"
          >{t('common.contactUs')} →</a
        >
      </p>
    </div>
  </div>
</Section>

<!-- Aperçu avis -->
<Section>
  <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
    <h2 class="text-2xl md:text-3xl">{t('home.reviewsTeaser')}</h2>
    <a href={localizeUrl(locale, 'reviews')} class="text-marine hover:underline"
      >{t('nav.reviews')} →</a
    >
  </div>
</Section>
