---
import { useTranslations } from '~/i18n/t';
import type { Locale } from '~/i18n/ui';
import ContactForm from '~/components/ContactForm.astro';
import MapEmbed from '~/components/MapEmbed.astro';
import { site } from '~/data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const howToCome = t<string[]>('contact.howToCome');
---

<!-- EN-TÊTE -->
<section class="bg-cream">
  <div class="mx-auto max-w-[1440px] px-5 pt-10 pb-5 md:px-14 md:pt-14 md:pb-8">
    <div class="max-w-[720px]">
      <p class="text-sage mb-3 text-[13px] font-semibold tracking-[0.16em] uppercase">
        {t('contact.eyebrow')}
      </p>
      <h1 class="font-display text-ink mb-3 text-[30px] leading-[1.1] font-semibold md:text-[44px]">
        {t('contact.title')}
      </h1>
      <p class="text-muted text-[15px] leading-[1.7] md:text-[17px]">{t('contact.intro')}</p>
    </div>
  </div>
</section>

<!-- DEUX COLONNES -->
<section class="bg-cream">
  <div
    class="mx-auto grid max-w-[1440px] items-start gap-6 px-5 pt-3 pb-12 md:grid-cols-2 md:gap-8 md:px-14 md:pt-6 md:pb-14"
  >
    <!-- GAUCHE : coordonnées + comment venir -->
    <div>
      <div class="bg-sand mb-6 rounded-xl border border-[#e4d8c4] p-6 md:p-8">
        <h2 class="font-display text-pine mb-5 text-[20px] font-semibold md:text-[22px]">
          {t('contact.coordsTitle')}
        </h2>
        <dl class="flex flex-col gap-[18px]">
          <div class="flex items-start gap-3.5">
            <span
              aria-hidden="true"
              class="border-sage text-pine flex h-[34px] w-[34px] flex-shrink-0 items-center justify-center rounded-lg border-[1.5px]"
              >☎</span
            >
            <div>
              <dt class="text-muted text-[13px]">{t('contact.phoneLabel')}</dt>
              <dd class="text-base">
                <a href={`tel:${site.phoneMobile}`} class="text-marine no-underline hover:underline"
                  >{t('common.phoneMobile')}</a
                >
              </dd>
            </div>
          </div>
          <div class="flex items-start gap-3.5">
            <span
              aria-hidden="true"
              class="border-sage text-pine flex h-[34px] w-[34px] flex-shrink-0 items-center justify-center rounded-lg border-[1.5px]"
              >✉</span
            >
            <div>
              <dt class="text-muted text-[13px]">{t('contact.emailLabel')}</dt>
              <dd class="text-base">
                <a href="#ecrire" class="text-marine no-underline hover:underline"
                  >{t('contact.viaForm')}</a
                >
              </dd>
            </div>
          </div>
          <div class="flex items-start gap-3.5">
            <span
              aria-hidden="true"
              class="border-sage text-pine flex h-[34px] w-[34px] flex-shrink-0 items-center justify-center rounded-lg border-[1.5px]"
              >⌖</span
            >
            <div>
              <dt class="text-muted text-[13px]">{t('contact.addressLabel')}</dt>
              <dd class="text-base leading-normal">
                {site.address.street}<br />{site.address.postalCode}
                {site.address.city} ({site.address.district})
              </dd>
            </div>
          </div>
        </dl>
      </div>

      <div class="bg-cream rounded-xl border border-[#e4d8c4] p-6 md:p-8">
        <h2 class="font-display text-pine mb-4 text-[20px] font-semibold md:text-[22px]">
          {t('contact.howToComeTitle')}
        </h2>
        <ul class="text-body flex flex-col gap-3.5 text-[15px] leading-relaxed">
          {
            howToCome.map((item) => (
              <li class="flex gap-3">
                <span aria-hidden="true" class="text-sage font-semibold">
                  ·
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- DROITE : formulaire -->
    <div id="ecrire" class="bg-sand scroll-mt-24 rounded-xl border border-[#e4d8c4] p-6 md:p-8">
      <h2 class="font-display text-pine mb-5 text-[20px] font-semibold md:text-[22px]">
        {t('contact.writeTitle')}
      </h2>
      <ContactForm locale={locale} />
    </div>
  </div>
</section>

<!-- CARTE -->
<section class="bg-cream">
  <div class="mx-auto max-w-[1440px] px-5 pb-12 md:px-14 md:pb-16">
    <MapEmbed title={t('contact.mapTitle')} />
  </div>
</section>
