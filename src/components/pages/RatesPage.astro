---
import { useTranslations } from '~/i18n/t';
import { localizeUrl, type Locale } from '~/i18n/ui';
import Section from '~/components/Section.astro';
import Button from '~/components/Button.astro';
import BookingEmbed from '~/components/BookingEmbed.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const grid = t<{ period: string; price: string }[]>('rates.grid');
const conditions = t<string[]>('rates.conditions');
---

<Section>
  <h1 class="text-3xl md:text-4xl">{t('rates.title')}</h1>
  <p class="mt-4 max-w-3xl text-sm text-muted">{t('rates.indicativeNote')}</p>
</Section>

<Section tone="sand">
  <h2 class="text-2xl md:text-3xl">{t('rates.weekTitle')}</h2>
  <p class="mt-3 max-w-3xl text-muted">{t('rates.weekIntro')}</p>

  <div class="mt-8 overflow-hidden rounded border border-beige">
    <table class="w-full border-collapse bg-white/50 text-left text-sm">
      <thead class="bg-pine/10">
        <tr>
          <th class="px-4 py-3 font-medium text-pine">{t('rates.tableSeason')}</th>
          <th class="px-4 py-3 font-medium text-pine">{t('rates.tablePrice')}</th>
        </tr>
      </thead>
      <tbody>
        {
          grid.map((row) => (
            <tr class="border-t border-beige/70">
              <td class="px-4 py-3">{row.period}</td>
              <td class="px-4 py-3 text-muted">{row.price}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="mt-8">
    <h3 class="text-lg">{t('rates.conditionsTitle')}</h3>
    <ul class="mt-3 space-y-2 text-sm text-muted">
      {conditions.map((c) => <li>· {c}</li>)}
    </ul>
    <p class="mt-4 text-xs text-muted">{t('rates.otaNote')}</p>
  </div>
</Section>

<Section>
  <h2 class="text-2xl md:text-3xl">{t('rates.bookingTitle')}</h2>
  <div class="mt-6">
    <BookingEmbed locale={locale} />
  </div>
</Section>

<Section tone="beige">
  <h2 class="text-2xl md:text-3xl">{t('rates.monthTitle')}</h2>
  <p class="mt-3 max-w-3xl text-muted">{t('rates.monthText')}</p>
  <div class="mt-6">
    <Button href={localizeUrl(locale, 'contact')} variant="outline">{t('rates.monthCta')}</Button>
  </div>
</Section>
