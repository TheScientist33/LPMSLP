---
import { useTranslations } from '~/i18n/t';
import type { Locale } from '~/i18n/ui';
import AvailabilityCalendar from '~/components/AvailabilityCalendar.astro';
import MonthlyRequestForm from '~/components/MonthlyRequestForm.astro';
import { tarifsSemaine, tarifMois } from '~/data/tarifs';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
// Grille de tarifs éditable : src/data/tarifs.ts
const grid = tarifsSemaine.map((r) => ({
  period: locale === 'fr' ? r.labelFr : r.labelEn,
  price: r.prix,
  option: r.option ?? false,
  divider: r.separateur ?? false,
}));
const monthUnit = locale === 'fr' ? tarifMois.uniteFr : tarifMois.uniteEn;
const monthNote = locale === 'fr' ? tarifMois.noteFr : tarifMois.noteEn;
---

<!-- EN-TÊTE -->
<section class="bg-cream">
  <div class="mx-auto max-w-[1440px] px-5 pt-10 pb-5 text-center md:px-14 md:pt-14 md:pb-8">
    <p class="text-sage mb-3 text-[13px] font-semibold tracking-[0.16em] uppercase">
      {t('rates.eyebrow')}
    </p>
    <h1
      class="font-display text-ink mb-3 text-[30px] leading-[1.12] font-semibold md:text-[44px] md:leading-[1.1]"
    >
      {t('rates.title')}
    </h1>
    <p class="text-muted mx-auto max-w-[620px] text-[15px] leading-[1.7] md:text-[17px]">
      {t('rates.intro')}
    </p>
  </div>
</section>

<!-- DEUX PARCOURS -->
<section class="bg-cream">
  <div
    class="mx-auto grid max-w-[1440px] items-start gap-6 px-5 pt-3 pb-12 md:grid-cols-2 md:gap-8 md:px-14 md:pt-6 md:pb-16"
  >
    <!-- A. SEMAINE -->
    <article class="bg-cream overflow-hidden rounded-xl border border-[#e4d8c4]">
      <header class="bg-pine text-cream px-5 py-5 md:px-[30px] md:py-6">
        <p class="text-footer-label mb-1.5 text-[12px] font-semibold tracking-[0.14em] uppercase">
          {t('rates.weekKicker')}
        </p>
        <h2 class="font-display text-[22px] font-semibold md:text-[26px]">
          {t('rates.weekTitle')}
        </h2>
        <p class="text-footer-text mt-1.5 text-[13px] md:text-sm">{t('rates.weekSubtitle')}</p>
      </header>
      <div class="p-5 md:p-[30px]">
        <p class="text-sage mb-3.5 text-[13px] font-semibold tracking-[0.12em] uppercase">
          {t('rates.gridLabel')}
        </p>
        <dl>
          {
            grid.map((row, i) => (
              <div
                class:list={[
                  'flex items-baseline justify-between gap-3 py-[13px]',
                  i < grid.length - 1 &&
                    (row.divider ? 'border-sand border-b-[3px]' : 'border-sand border-b'),
                ]}
              >
                <dt class:list={['text-[15px] md:text-base', row.option && 'text-muted']}>
                  {row.period}
                </dt>
                <dd
                  class:list={[
                    'font-display text-right text-base md:text-[17px]',
                    row.option ? 'text-marine' : 'text-pine',
                  ]}
                >
                  {row.price}
                </dd>
              </div>
            ))
          }
        </dl>
        <p class="bg-sand text-body mt-5 rounded-lg px-[18px] py-4 text-sm leading-relaxed">
          <strong class="text-pine">{t('rates.conditionsLabel')}</strong>
          {' '}{t('rates.conditionsText')}
        </p>

        <div class="mt-6">
          <AvailabilityCalendar locale={locale} />
        </div>
      </div>
    </article>

    <!-- B. MOIS -->
    <article
      id="mois"
      class="bg-sand scroll-mt-24 overflow-hidden rounded-xl border border-[#e4d8c4]"
    >
      <header class="bg-sage text-cream px-5 py-5 md:px-[30px] md:py-6">
        <p class="mb-1.5 text-[12px] font-semibold tracking-[0.14em] text-[#e7eee8] uppercase">
          {t('rates.monthKicker')}
        </p>
        <h2 class="font-display text-[22px] font-semibold md:text-[26px]">
          {t('rates.monthTitle')}
        </h2>
        <p class="mt-1.5 text-[13px] text-[#eaf1ec] md:text-sm">
          {t('rates.monthSubtitle1')}<br />{t('rates.monthSubtitle2')}
        </p>
      </header>
      <div class="p-5 md:p-[30px]">
        <p class="text-body mb-5 text-[15px] leading-[1.7] md:text-base">{t('rates.monthText')}</p>
        <div class="bg-cream mb-6 rounded-lg border border-[#e4d8c4] px-5 py-5 md:px-[22px]">
          <p class="text-muted mb-1 text-[13px]">{t('rates.monthPriceLabel')}</p>
          <p class="font-display text-pine text-[28px] md:text-[34px]">
            {tarifMois.prix}
            <span class="text-muted font-sans text-base font-normal">{monthUnit}</span>
          </p>
          <p class="text-muted mt-1 text-[13px]">{monthNote}</p>
        </div>

        <p class="text-sage mb-4 text-[13px] font-semibold tracking-[0.12em] uppercase">
          {t('rates.monthFormLabel')}
        </p>
        <MonthlyRequestForm locale={locale} />
      </div>
    </article>
  </div>
</section>
