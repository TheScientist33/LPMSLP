---
import { useTranslations } from '~/i18n/t';
import type { Locale } from '~/i18n/ui';
import Section from '~/components/Section.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const bedrooms = t<string[]>('house.bedrooms');
const equipment = t<string[]>('house.equipment');
const notes = t<string[]>('house.notes');
---

<Section>
  <h1 class="text-3xl md:text-4xl">{t('house.title')}</h1>
  <p class="mt-6 max-w-3xl text-lg text-muted">{t('house.intro')}</p>
</Section>

<Section tone="sand">
  <div class="grid gap-10 md:grid-cols-2">
    <div class="fade-up">
      <h2 class="text-2xl">{t('house.livingTitle')}</h2>
      <p class="mt-3 text-muted">{t('house.livingText')}</p>
    </div>
    <div class="fade-up">
      <h2 class="text-2xl">{t('house.kitchenTitle')}</h2>
      <p class="mt-3 text-muted">{t('house.kitchenText')}</p>
    </div>
    <div class="fade-up">
      <h2 class="text-2xl">{t('house.bedroomsTitle')}</h2>
      <ul class="mt-3 space-y-1 text-muted">
        {bedrooms.map((b) => <li>· {b}</li>)}
      </ul>
    </div>
    <div class="fade-up">
      <h2 class="text-2xl">{t('house.outdoorTitle')}</h2>
      <p class="mt-3 text-muted">{t('house.outdoorText')}</p>
    </div>
  </div>
</Section>

<Section>
  <h2 class="text-2xl md:text-3xl">{t('house.equipmentTitle')}</h2>
  <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      equipment.map((e) => (
        <li class="flex items-start gap-2 text-muted">
          <span aria-hidden="true" class="mt-1 text-sage">✓</span>
          <span>{e}</span>
        </li>
      ))
    }
  </ul>
</Section>

<Section tone="beige">
  <div class="grid gap-10 md:grid-cols-2">
    <div>
      <h2 class="text-2xl">{t('house.accessTitle')}</h2>
      <p class="mt-3 text-muted">{t('house.accessText')}</p>
    </div>
    <div>
      <h2 class="text-2xl">{t('house.notesTitle')}</h2>
      <ul class="mt-3 space-y-2 text-sm text-muted">
        {notes.map((n) => <li>· {n}</li>)}
      </ul>
    </div>
  </div>
</Section>
