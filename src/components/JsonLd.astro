---
import { site } from '~/data/site';
import type { Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const data = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: site.name,
  url: siteUrl,
  telephone: site.phoneMobile,
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: `${site.address.city} (${site.address.district})`,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.address.lat,
    longitude: site.address.lng,
  },
  amenityFeature: [
    {
      '@type': 'LocationFeatureSpecification',
      name: locale === 'fr' ? 'Piscine intérieure chauffée' : 'Heated indoor pool',
      value: true,
    },
    {
      '@type': 'LocationFeatureSpecification',
      name: locale === 'fr' ? 'Spa (option)' : 'Spa (option)',
      value: true,
    },
    {
      '@type': 'LocationFeatureSpecification',
      name: locale === 'fr' ? 'Climatisation' : 'Air conditioning',
      value: true,
    },
    { '@type': 'LocationFeatureSpecification', name: 'Internet', value: true },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(data)} is:inline />
