---
import { site } from '~/data/site';
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="overflow-hidden rounded border border-beige shadow-sm">
  <iframe
    src={site.mapEmbedUrl}
    title={title}
    width="100%"
    height="420"
    style="border:0"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen></iframe>
</div>
