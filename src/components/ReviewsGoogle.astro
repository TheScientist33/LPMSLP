---
import { useTranslations } from '~/i18n/t';
import { site } from '~/data/site';
import type { Locale } from '~/i18n/ui';
import { getReviews } from '~/lib/reviews';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const data = await getReviews();
---

{
  data ? (
    <div class="space-y-8">
      <div class="flex items-baseline gap-3">
        <span class="font-display text-4xl text-pine">{data.rating.toFixed(1)}</span>
        <span class="text-muted">
          / 5 · {data.total} {locale === 'fr' ? 'avis' : 'reviews'}
        </span>
      </div>
      <ul class="grid gap-6 md:grid-cols-2">
        {data.reviews.map((r) => (
          <li class="rounded border border-beige bg-white/60 p-6 shadow-sm">
            <p class="text-pine">{'★'.repeat(r.rating)}<span class="text-beige">{'★'.repeat(5 - r.rating)}</span></p>
            <p class="mt-2 text-sm text-ink">{r.text}</p>
            <p class="mt-3 text-xs text-muted">— {r.author}</p>
          </li>
        ))}
      </ul>
    </div>
  ) : (
    <div class="rounded border border-dashed border-beige bg-beige/30 p-8 text-center">
      <p class="text-muted">{t('reviews.placeholder')}</p>
    </div>
  )
}

{
  site.placeId && (
    <p class="mt-6">
      <a
        href={`https://search.google.com/local/reviews?placeid=${site.placeId}`}
        target="_blank"
        rel="noopener"
        class="text-marine hover:underline"
      >
        {t('reviews.seeAll')} →
      </a>
    </p>
  )
}
