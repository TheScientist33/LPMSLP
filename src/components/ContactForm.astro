---
import { useTranslations } from '~/i18n/t';
import type { Locale } from '~/i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const f = (k: string) => t(`contact.form.${k}`);
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const inputCls =
  'w-full rounded-md border border-[#dacdb6] bg-cream px-3.5 py-3 text-sm text-ink placeholder:text-[#9a907f]';
const labelCls = 'mb-1.5 block text-[13px] text-muted';
---

<form class="js-form" data-endpoint="/api/contact" novalidate>
  <input type="hidden" name="locale" value={locale} />
  <div class="hidden" aria-hidden="true">
    <label
      >Ne pas remplir <input type="text" name="company" tabindex="-1" autocomplete="off" /></label
    >
  </div>

  <div class="flex flex-col gap-3.5">
    <div>
      <label for="cf-name" class={labelCls}>{f('name')}</label>
      <input
        id="cf-name"
        name="name"
        type="text"
        required
        autocomplete="name"
        placeholder={f('namePlaceholder')}
        class={inputCls}
      />
    </div>
    <div>
      <label for="cf-email" class={labelCls}>{f('email')}</label>
      <input
        id="cf-email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder={f('emailPlaceholder')}
        class={inputCls}
      />
    </div>
    <div>
      <label for="cf-phone" class={labelCls}>
        {f('phone')}
        <span class="text-[#9a907f]">{f('phoneOptional')}</span>
      </label>
      <input
        id="cf-phone"
        name="phone"
        type="tel"
        autocomplete="tel"
        placeholder={f('phonePlaceholder')}
        class={inputCls}
      />
    </div>
    <div>
      <label for="cf-message" class={labelCls}>{f('message')}</label>
      <textarea
        id="cf-message"
        name="message"
        rows="5"
        required
        placeholder={f('messagePlaceholder')}
        class={inputCls}></textarea>
    </div>
  </div>

  <label class="text-muted my-4 flex items-start gap-2.5 text-[13px] leading-normal">
    <input name="consent" type="checkbox" required class="accent-pine mt-0.5 h-[18px] w-[18px]" />
    <span>{f('consent')}</span>
  </label>

  {turnstileKey && <div class="cf-turnstile mb-4" data-sitekey={turnstileKey} data-theme="light" />}

  <button
    type="submit"
    class="js-submit bg-pine text-cream hover:bg-pine/90 flex min-h-11 w-full items-center justify-center rounded-md px-6 py-[15px] text-base font-medium transition-colors disabled:opacity-60"
  >
    {f('submit')}
  </button>

  <p class="js-success text-pine mt-3 hidden text-sm" role="status">{f('success')}</p>
  <p class="js-error text-notice-strong mt-3 hidden text-sm" role="alert">{f('error')}</p>
</form>

{
  turnstileKey && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline />
  )
}

<script>
  import { bindAjaxForms } from '~/lib/form-client';
  bindAjaxForms();
</script>
