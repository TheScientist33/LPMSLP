# Emails (Resend) — formulaires contact & demande au mois
RESEND_API_KEY=
# Adresse qui reçoit les messages des formulaires (définie dans Vercel, pas ici).
CONTACT_TO_EMAIL=

# Anti-spam (Cloudflare Turnstile)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Avis Google — activer « Places API (New) » dans Google Cloud, puis coller la clé.
# (Le Place ID est déjà dans src/data/site.ts, non secret.)
GOOGLE_PLACES_API_KEY=

# URL publique du site
PUBLIC_SITE_URL=https://lapetitemaisonsouslespins.fr
